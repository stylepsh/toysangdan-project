rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 상품 이미지: 누구나 읽기, 관리자만 쓰기
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 회원 사업자등록증: 본인+관리자만
    match /members/{memberId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
